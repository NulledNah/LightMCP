# LightMCP Environment Variables
# Copy this file to .env and fill in your values

# Override MCP server definitions (absolute path)
# Takes priority over all other sources (inline config, agent detection)
# LIGHTMCP_MCP_CONFIG=/home/user/my-servers.json

# Deprecated: set mcpConfigPath in lightmcp_config.json instead
# MCP_CONFIG_PATH=C:\Users\YourName\.gemini\antigravity\mcp_config.json
